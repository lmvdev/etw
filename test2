local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local inspectorName = "InteractiveInspector"
if playerGui:FindFirstChild(inspectorName) then playerGui[inspectorName]:Destroy() end

-- 1. Интерфейс
local screenGui = Instance.new("ScreenGui")
screenGui.Name = inspectorName
screenGui.Parent = playerGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0.9, 0, 0.8, 0)
mainFrame.Position = UDim2.new(0.05, 0, 0.1, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
mainFrame.Parent = screenGui

local closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0, 40, 0, 40)
closeButton.Position = UDim2.new(1, -45, 0, 5)
closeButton.Text = "X"
closeButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
closeButton.TextColor3 = Color3.new(1, 1, 1)
closeButton.Parent = mainFrame
closeButton.MouseButton1Click:Connect(function() screenGui:Destroy() end)

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -10, 1, -50)
scroll.Position = UDim2.new(0, 5, 0, 45)
scroll.BackgroundTransparency = 1
scroll.AutomaticCanvasSize = Enum.AutomaticSize.XY
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.Parent = mainFrame

local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 2)
layout.Parent = scroll

-- 2. Функция создания элемента дерева
local function createEntry(object, parentFrame, indent)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 25)
    frame.BackgroundTransparency = 1
    frame.Parent = parentFrame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Position = UDim2.new(0, indent * 20, 0, 0)
    button.BackgroundTransparency = 0.9
    button.BackgroundColor3 = Color3.new(1, 1, 1)
    button.BorderSizePixel = 0
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Font = Enum.Font.Code
    button.TextSize = 14
    button.TextColor3 = object.Name == "Sell" and Color3.new(0, 1, 1) or Color3.new(0.9, 0.9, 0.9)
    
    -- Текст с основными свойствами
    local displayName = (object:GetChildren()[1] and "[+] " or "    ") .. object.Name
    if object:IsA("GuiObject") then
        displayName ..= " | Vis:" .. tostring(object.Visible)
    end
    if object:IsA("TextLabel") or object:IsA("TextButton") then
        displayName ..= " | Text:'" .. object.Text .. "'"
    end
    button.Text = displayName
    button.Parent = frame

    -- Контейнер для детей
    local childContainer = Instance.new("Frame")
    childContainer.Size = UDim2.new(1, 0, 0, 0)
    childContainer.AutomaticSize = Enum.AutomaticSize.Y
    childContainer.BackgroundTransparency = 1
    childContainer.Visible = false
    childContainer.Parent = parentFrame
    
    local childLayout = Instance.new("UIListLayout")
    childLayout.Padding = UDim.new(0, 2)
    childLayout.Parent = childContainer

    -- Логика раскрытия
    local expanded = false
    button.MouseButton1Click:Connect(function()
        if not object:GetChildren()[1] then return end
        expanded = not expanded
        childContainer.Visible = expanded
        button.Text = (expanded and "[-] " or "[+] ") .. object.Name .. (displayName:sub(#object.Name + 5))
    end)

    -- Предварительная загрузка детей (создаются только при раскрытии для оптимизации)
    local childrenLoaded = false
    button.MouseButton1Click:Connect(function()
        if not childrenLoaded then
            for _, child in pairs(object:GetChildren()) do
                if child.Name ~= inspectorName then
                    createEntry(child, childContainer, indent + 1)
                end
            end
            childrenLoaded = true
        end
    end)
end

-- 3. Запуск
for _, gui in pairs(playerGui:GetChildren()) do
    if gui:IsA("ScreenGui") and gui.Name ~= inspectorName then
        createEntry(gui, scroll, 0)
    end
end
