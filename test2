-- 2. Логика координат
RunService.RenderStepped:Connect(function()
    local character = player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        local pos = character.HumanoidRootPart.Position
        posLabel.Text = string.format("Координаты: X: %.2f | Y: %.2f | Z: %.2f", pos.X, pos.Y, pos.Z)
    else
        posLabel.Text = "Координаты: Персонаж не найден"
    end
end)

-- 3. Функции элементов (из прошлых шагов)
local function addSectionHeader(text, color)
    local header = Instance.new("TextLabel")
    header.Size = UDim2.new(1, 0, 0, 30)
    header.BackgroundColor3 = color
    header.BackgroundTransparency = 0.5
    header.Text = "  " .. text
    header.TextColor3 = Color3.new(1, 1, 1)
    header.Font = Enum.Font.GothamBold
    header.TextSize = 16
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.Parent = scroll
end

local function createEntry(object, parentFrame, indent)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 25)
    frame.BackgroundTransparency = 1
    frame.Parent = parentFrame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Position = UDim2.new(0, indent * 15, 0, 0)
    button.BackgroundTransparency = 0.95
    button.BackgroundColor3 = Color3.new(1, 1, 1)
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Font = Enum.Font.Code
    button.TextSize = 13
    button.TextColor3 = (object.Name == "Sell") and Color3.new(0, 1, 1) or Color3.new(0.8, 0.8, 0.8)
    
    local props = ""
    if object:IsA("GuiObject") then props ..= " | Vis:" .. tostring(object.Visible) end
    if object:IsA("TextLabel") or object:IsA("TextButton") then props ..= " | Text:'" .. object.Text .. "'" end
    if object:IsA("BasePart") then props ..= " | CanCol:" .. tostring(object.CanCollide) end

    local hasChildren = #object:GetChildren() > 0
    button.Text = (hasChildren and "[+] " or "    ") .. object.Name .. " [" .. object.ClassName .. "]" .. props
    button.Parent = frame

    local childContainer = Instance.new("Frame")
    childContainer.Size = UDim2.new(1, 0, 0, 0)
    childContainer.AutomaticSize = Enum.AutomaticSize.Y
    childContainer.BackgroundTransparency = 1
    childContainer.Visible = false
    childContainer.Parent = parentFrame
    Instance.new("UIListLayout", childContainer)

    local expanded = false
    local childrenLoaded = false
    button.MouseButton1Click:Connect(function()
        if not hasChildren then return end
        expanded = not expanded
        childContainer.Visible = expanded
        if not childrenLoaded then
            for _, child in pairs(object:GetChildren()) do
                if child.Name ~= inspectorName then createEntry(child, childContainer, indent + 1) end
            end
            childrenLoaded = true
        end
        button.Text = (expanded and "[-] " or "[+] ") .. object.Name .. " [" .. object.ClassName .. "]" .. props
    end)
end

-- ЗАПУСК
addSectionHeader("GUI INTERFACES", Color3.fromRGB(0, 85, 255))
for _, gui in pairs(playerGui:GetChildren()) do
    if gui:IsA("ScreenGui") and gui.Name ~= inspectorName then createEntry(gui, scroll, 0) end
end

addSectionHeader("WORKSPACE OBJECTS", Color3.fromRGB(85, 170, 0))
for _, obj in pairs(Workspace:GetChildren()) do createEntry(obj, scroll, 0) end
