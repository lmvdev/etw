local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local inspectorName = "FullInspector"
if playerGui:FindFirstChild(inspectorName) then playerGui[inspectorName]:Destroy() end

-- 1. Интерфейс
local screenGui = Instance.new("ScreenGui")
screenGui.Name = inspectorName
screenGui.Parent = playerGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0.9, 0, 0.8, 0)
mainFrame.Position = UDim2.new(0.05, 0, 0.1, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
mainFrame.Parent = screenGui

local closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0, 40, 0, 40)
closeButton.Position = UDim2.new(1, -45, 0, 5)
closeButton.Text = "X"
closeButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
closeButton.TextColor3 = Color3.new(1, 1, 1)
closeButton.Parent = mainFrame
closeButton.MouseButton1Click:Connect(function() screenGui:Destroy() end)

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -10, 1, -50)
scroll.Position = UDim2.new(0, 5, 0, 45)
scroll.BackgroundTransparency = 1
scroll.AutomaticCanvasSize = Enum.AutomaticSize.XY
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.Parent = mainFrame

local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 2)
layout.Parent = scroll

-- Заголовки секций
local function addSectionHeader(text, color)
    local header = Instance.new("TextLabel")
    header.Size = UDim2.new(1, 0, 0, 30)
    header.BackgroundColor3 = color
    header.BackgroundTransparency = 0.5
    header.Text = "  " .. text
    header.TextColor3 = Color3.new(1, 1, 1)
    header.Font = Enum.Font.GothamBold
    header.TextSize = 16
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.Parent = scroll
end

-- 2. Функция создания элемента дерева
local function createEntry(object, parentFrame, indent)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 25)
    frame.BackgroundTransparency = 1
    frame.Parent = parentFrame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Position = UDim2.new(0, indent * 15, 0, 0)
    button.BackgroundTransparency = 0.95
    button.BackgroundColor3 = Color3.new(1, 1, 1)
    button.BorderSizePixel = 0
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.Font = Enum.Font.Code
    button.TextSize = 13
    button.TextColor3 = (object.Name == "Sell") and Color3.new(0, 1, 1) or Color3.new(0.8, 0.8, 0.8)
    
    -- Формирование текста свойств
    local props = ""
    if object:IsA("GuiObject") then
        props ..= " | Vis:" .. tostring(object.Visible)
    end
    if object:IsA("TextLabel") or object:IsA("TextButton") then
        props ..= " | Text:'" .. object.Text .. "'"
    end
    -- Для Workspace добавим прозрачность и столкновение для интереса
    if object:IsA("BasePart") then
        props ..= " | Tr:" .. math.floor(object.Transparency * 10)/10 .. " | CanCol:" .. tostring(object.CanCollide)
    end

    local hasChildren = #object:GetChildren() > 0
    button.Text = (hasChildren and "[+] " or "    ") .. object.Name .. " [" .. object.ClassName .. "]" .. props
    button.Parent = frame

    local childContainer = Instance.new("Frame")
    childContainer.Size = UDim2.new(1, 0, 0, 0)
    childContainer.AutomaticSize = Enum.AutomaticSize.Y
    childContainer.BackgroundTransparency = 1
    childContainer.Visible = false
    childContainer.Parent = parentFrame
    
    Instance.new("UIListLayout", childContainer).Padding = UDim.new(0, 2)

    local expanded = false
    local childrenLoaded = false
    button.MouseButton1Click:Connect(function()
        if not hasChildren then return end
        expanded = not expanded
        childContainer.Visible = expanded
        
        -- Динамическая загрузка
        if not childrenLoaded then
            for _, child in pairs(object:GetChildren()) do
                if child.Name ~= inspectorName then
                    createEntry(child, childContainer, indent + 1)
                end
            end
            childrenLoaded = true
        end
        
        button.Text = (expanded and "[-] " or "[+] ") .. object.Name .. " [" .. object.ClassName .. "]" .. props
    end)
end

-- 3. ЗАПУСК
addSectionHeader("GUI INTERFACES", Color3.fromRGB(0, 85, 255))
for _, gui in pairs(playerGui:GetChildren()) do
    if gui:IsA("ScreenGui") and gui.Name ~= inspectorName then
        createEntry(gui, scroll, 0)
    end
end

addSectionHeader("WORKSPACE OBJECTS", Color3.fromRGB(85, 170, 0))
for _, obj in pairs(Workspace:GetChildren()) do
    -- Исключаем камеру и персонажа (чтобы не спамить), но можно оставить
    createEntry(obj, scroll, 0)
end
